{
  "name": "Song",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "composer": {
      "type": "string"
    },
    "instrument": {
      "type": "string",
      "enum": [
        "piano",
        "guitar",
        "violin",
        "flute",
        "drums",
        "bass",
        "ukulele",
        "other"
      ]
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "beginner",
        "intermediate",
        "advanced",
        "expert"
      ]
    },
    "tempo": {
      "type": "number"
    },
    "genre": {
      "type": "string"
    },
    "file_url": {
      "type": "string"
    },
    "file_type": {
      "type": "string"
    },
    "notes_data": {
      "type": "string"
    },
    "analysis_result": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "processing",
        "ready",
        "error"
      ],
      "default": "processing"
    },
    "current_level": {
      "type": "number",
      "default": 1
    },
    "levels_unlocked": {
      "type": "number",
      "default": 1
    },
    "xp_reward": {
      "type": "number",
      "default": 100
    }
  },
  "required": [
    "title"
  ]
}